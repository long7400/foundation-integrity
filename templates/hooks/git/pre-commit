#!/usr/bin/env sh
# foundation-integrity :: git pre-commit
#
# Runtime-neutral, canonical enforcement — fires for EVERY actor (Claude, Codex, and a
# human on the CLI), so a foundation check here can't be sidestepped by switching
# runtime. Kept fast: warn-only, so it never becomes the reason someone reaches for
# `--no-verify`.
#
# Install: copy to .git/hooks/pre-commit and `chmod +x`, or point core.hooksPath at
# the dir holding this file. Keep the wiring explicit and reviewable.
#
# Adjust the path below if you vendored the scripts elsewhere.
set -eu
root=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
DIR="$root/.foundation-integrity/hooks"
cd "$root"

# Surface-guard: warn if a foundation-surface file changed with no valid receipt. Warn only
# at commit time (blocking belongs on pre-push).
[ -x "$DIR/foundation-surface-guard.sh" ] && "$DIR/foundation-surface-guard.sh" || true

# Cheap git delta only. Stack adapters are intentionally deferred until pre-push/CI
# or an explicitly merged runtime hook, after the project has selected its adapter.
[ -x "$DIR/fitness-check.sh" ] && FI_DELTA_ONLY=1 "$DIR/fitness-check.sh" || true

exit 0
