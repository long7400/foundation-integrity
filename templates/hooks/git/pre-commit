#!/usr/bin/env sh
# foundation-integrity :: git pre-commit
#
# Runtime-neutral, canonical enforcement — fires for EVERY actor (Claude, Codex, and a
# human on the CLI), so a foundation check here can't be sidestepped by switching
# runtime. Kept fast: warn-only, so it never becomes the reason someone reaches for
# `--no-verify`.
#
# Install: copy to .git/hooks/pre-commit and `chmod +x`, or point core.hooksPath at
# the dir holding this file. Keep the wiring explicit and reviewable.
#
set -eu
root=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
DIR=
runtime=$(awk -F '\t' '$1 == "setting" && $2 == "runtime" { print $3; exit }' \
  "$root/.foundation-integrity/adoption.tsv" 2>/dev/null || true)
case "$runtime" in
  codex)
    DIR=$root/.codex/hooks/scripts
    ;;
  claude)
    DIR=$root/.claude/hooks/scripts
    ;;
  both)
    codex_dir=$root/.codex/hooks/scripts
    claude_dir=$root/.claude/hooks/scripts
    if [ ! -x "$codex_dir/foundation-surface-guard.sh" ] \
      || [ ! -x "$claude_dir/foundation-surface-guard.sh" ]; then
      printf '%s\n' "foundation-integrity: both-runtime hook copies are incomplete; refusing git checks" >&2
      exit 0
    fi
    for shared in foundation-surface.txt foundation-surface-guard.sh fitness-check.sh; do
      if ! cmp -s "$codex_dir/$shared" "$claude_dir/$shared"; then
        printf '%s\n' "foundation-integrity: both-runtime hook copies diverged; refusing git checks" >&2
        exit 0
      fi
    done
    DIR=$codex_dir
    ;;
  *)
    printf '%s\n' "foundation-integrity: adoption ledger has no valid runtime owner; skipping warn-only git checks" >&2
    exit 0
    ;;
esac
if [ ! -x "$DIR/foundation-surface-guard.sh" ] || [ ! -x "$DIR/fitness-check.sh" ]; then
  printf '%s\n' "foundation-integrity: recorded runtime hook scripts are incomplete; skipping warn-only git checks" >&2
  exit 0
fi
cd "$root"

# Surface-guard: warn if a foundation-surface file changed with no valid receipt. Warn only
# at commit time (blocking belongs on pre-push).
[ -x "$DIR/foundation-surface-guard.sh" ] && "$DIR/foundation-surface-guard.sh" || true

# Cheap git delta only. Stack adapters are intentionally deferred until pre-push/CI
# or an explicitly merged runtime hook, after the project has selected its adapter.
[ -x "$DIR/fitness-check.sh" ] && FI_DELTA_ONLY=1 "$DIR/fitness-check.sh" || true

exit 0
