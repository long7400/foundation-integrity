{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'sh \"$(git rev-parse --show-toplevel)/.foundation-integrity/hooks/foundation-surface-guard.sh\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'FI_DELTA_ONLY=1 sh \"$(git rev-parse --show-toplevel)/.foundation-integrity/hooks/fitness-check.sh\"'"
          }
        ]
      }
    ]
  }
}
