# Editor / IDE
.idea/
.vscode/
*.swp
.DS_Store

# Node (only if a stack ever lands here)
node_modules/

# Foundation Integrity runtime, research, plan, and Herdr/process artifacts are
# session-local and must never be pushed from a consumer repo.
.foundation/

# Per-project research notes and foundation receipts are local working material.
# Promote only decision-lossless conclusions into an explicitly tracked project
# document when they truly need to be shared.
docs/research/*
!docs/research/.gitkeep
docs/foundation/receipts/*
!docs/foundation/receipts/.gitkeep

# Personal ADR working history. Keep only the reusable template in the pack.
docs/adr/*.md
!docs/adr/0000-template.md

# User-provided scratch inputs (for example a temporary skill drop) are local only.
tmp/
